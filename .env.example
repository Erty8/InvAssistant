# ==========================================
# Portfolio Monitoring AI Agent System Config
# ==========================================

# 1. LLM Provider Configuration
# Set to 'openai', 'gemini', or 'anthropic' to select the provider.
# Helps bypass OpenAI rate limits or quota issues.
LLM_PROVIDER=openai

# 1A. OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Optionally configure custom base URL (e.g. OpenRouter, Ollama, DeepSeek)
# OPENAI_API_BASE=https://api.openai.com/v1

# 1B. Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.5-flash

# 1C. Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# 2. Portfolio Configuration
PORTFOLIO_TICKERS=AAPL,MSFT,NVDA,AMZN,GOOGL

# 3. Notification (SMTP Email) Settings
SENDER_EMAIL=your-sender-email@gmail.com
RECEIVER_EMAIL=your-receiving-email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-app-password
SMTP_USE_TLS=True

# 4. Scheduling & Execution Config
SAVE_LOCAL_COPY=True
