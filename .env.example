# ==========================================
# Portfolio Monitoring AI Agent System Config
# ==========================================

# 1. LLM Provider configuration (Defaults to OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Optionally configure custom base URL (e.g., for local models, OpenRouter, etc.)
# OPENAI_API_BASE=https://api.openai.com/v1

# 2. Portfolio Configuration
PORTFOLIO_TICKERS=AAPL,MSFT,NVDA,AMZN,GOOGL

# 3. Notification (SMTP Email) Settings
SENDER_EMAIL=your-sender-email@gmail.com
RECEIVER_EMAIL=your-receiving-email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-app-password
SMTP_USE_TLS=True

# 4. Scheduling & Execution Config
# Set to True to output generated reports as local HTML files in 'reports/' directory,
# even if email sending fails or is not configured.
SAVE_LOCAL_COPY=True
